# ===========================================
# Career Universe - Environment Configuration
# ===========================================

# Database (Supabase PostgreSQL)
# -----------------------------
# Port 6543 = Transaction Pooler (für App-Verbindungen mit pgbouncer)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"

# Port 5432 = Direct Connection (für Prisma Migrationen)
DIRECT_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase (optional)
# -------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"

# Anthropic AI (for Career Mentor)
# --------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Next.js
# -------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
