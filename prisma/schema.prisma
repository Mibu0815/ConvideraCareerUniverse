enum ChangeType {
  SELF_ASSESSMENT
  VALIDATION
  ROLE_CHANGE
}

enum CoachingType {
  GAP_ANALYSIS
  LEARNING_PATH
  CAREER_EXPLORATION
  SKILL_DEVELOPMENT
  ASSESSMENT_PREP
  GENERAL
}

enum DigestStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum FocusPriority {
  CRITICAL
  GROWTH
  STRETCH
}

enum FocusStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum GoalStatus {
  EXPLORING
  COMMITTED
  ACHIEVED
  PAUSED
}

enum ImpulseLevel {
  L1_AWARENESS
  L2_GUIDED
  L3_INDEPENDENT
  L4_EXPERT
}

enum ImpulseStep {
  CHECK_IN    /// Begrüßung und Skill-Kontext
  TASK        /// Aufgabe wird bearbeitet
  REFLECTION  /// Reflexion über Herausforderungen
  EVIDENCE    /// Beleg für Functional Lead gespeichert
}

enum MessageRole {
  USER
  ASSISTANT
}

enum NotificationChannel {
  EMAIL
  SLACK
  IN_APP
}

enum PlatformRole {
  ADMIN
  FUNCTIONAL_LEAD
  MEMBER
}

enum ResourceType {
  BOOK
  VIDEO
  COURSE
  ARTICLE
  INTERNAL_SESSION
  MENTOR
  PROJECT
  CERTIFICATION
}

enum RoleLevel {
  JUNIOR
  PROFESSIONAL
  SENIOR
  FUNCTIONAL_LEAD
  HEAD_OF
}

enum TrendDirection {
  rising
  stable
  declining
}
