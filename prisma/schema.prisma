}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model LearningResource {
  id                String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  title             String
  url               String?
  type              ResourceType
  description       String?
  createdById       String
  competenceFieldId String?
  createdAt         DateTime         @default(now()) @db.Timestamp(6)
  CompetenceField   CompetenceField? @relation(fields: [competenceFieldId], references: [id], onUpdate: NoAction)
  User              User             @relation(fields: [createdById], references: [id], onDelete: Cascade, onUpdate: NoAction)
