generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CompetenceField {
  id            String          @id @default(cuid())
  title         String          @unique
  slug          String          @unique
  color         String?
  ownerId       String?
  Owner         User?           @relation("CompetenceFieldOwner", fields: [ownerId], references: [id])
  Skill         Skill[]
  LearningFocus LearningFocus[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OccupationalField {
  id    String @id @default(cuid())
  title String @unique
  slug  String @unique
  Role  Role[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Responsibility {
  id       String  @id @default(cuid())
  text     String
  category String?
  order    Int     @default(0)
  roleId   String
  Role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([roleId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Role {
  id                String            @id @default(cuid())
  title             String
  slug              String            @unique
  level             RoleLevel
  description       String?
  team              String?           @default("Squad")
  hasLeadership     Boolean           @default(false)
  leadershipType    String?
  hasBudgetResp     Boolean           @default(false)
  directReportTo    String?
  language          String?           @default("english")
  fieldId           String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  Responsibility    Responsibility[]
  OccupationalField OccupationalField @relation(fields: [fieldId], references: [id])
  RoleSkill         RoleSkill[]
  SoftSkill         SoftSkill[]
  CareerGoal        CareerGoal[]
  PathsFrom         CareerPath[]      @relation("CareerPathFrom")
  PathsTo           CareerPath[]      @relation("CareerPathTo")

  @@index([fieldId])
  @@index([level])
}

model CareerPath {
  id          String   @id @default(cuid())
  fromRoleId  String
  toRoleId    String
  isTypical   Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  FromRole Role @relation("CareerPathFrom", fields: [fromRoleId], references: [id], onDelete: Cascade)
  ToRole   Role @relation("CareerPathTo", fields: [toRoleId], references: [id], onDelete: Cascade)

  @@unique([fromRoleId, toRoleId])
  @@index([fromRoleId])
  @@index([toRoleId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Skill {
  id                 String              @id @default(cuid())
  title              String
  slug               String              @unique
  description        String?
  fieldId            String
  // AI Content Fields (Hybrid-Skill Card)
  coreDescription    String? // Fundamental knowledge (2020 basis)
  aiLayerDescription String? // AI-powered approach (2026 upgrade)
  aiToolTip          String? // Recommended AI tool
  realWorldCaseLink  String? // Link to internal project/repo
  realWorldExpert    String? // Internal expert name
  lastAiUpdate       DateTime? // When Claude last updated content
  RoleSkill          RoleSkill[]
  CompetenceField    CompetenceField     @relation(fields: [fieldId], references: [id])
  UserSkillEvidence  UserSkillEvidence[]
  LearningFocus      LearningFocus[]
  SkillAssessment    SkillAssessment[]
  Evidence           Evidence[]
  AssessmentHistory  AssessmentHistory[]

  @@unique([title, fieldId])
  @@index([fieldId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model SoftSkill {
  id       String  @id @default(cuid())
  title    String  @unique
  slug     String  @unique
  category String?
  Role     Role[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id                    String              @id
  email                 String              @unique
  name                  String?
  avatarUrl             String?
  currentRoleId         String?
  targetRoleId          String?
  platformRole          PlatformRole        @default(USER)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime
  TimelineEntry         TimelineEntry[]
  UserSkillEvidence     UserSkillEvidence[]
  LearningPlan          LearningPlan?
  SkillAssessment       SkillAssessment[]
  CareerGoal            CareerGoal[]
  OwnedCompetenceFields CompetenceField[]   @relation("CompetenceFieldOwner")
  ActivityLog           ActivityLog[]
  Feedback              Feedback[]
  Evidence              Evidence[]
  ValidatedEvidence     Evidence[]          @relation("ValidatedEvidence")
  ValidationEvent       ValidationEvent[]
  TimelineEvent         TimelineEvent[]
  AssessmentHistory     AssessmentHistory[]
  AssessedHistory       AssessmentHistory[] @relation("AssessmentHistoryAssessor")

  @@index([email])
  @@index([platformRole])
}

model RoleSkill {
  roleId   String
  skillId  String
  minLevel Int
  Role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  Skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([roleId, skillId])
  @@index([skillId])
}

model SkillValidationConfig {
  id                      String   @id @default(cuid())
  skillId                 String   @unique
  level1Points            Int      @default(10)
  level2Points            Int      @default(30)
  level3Points            Int      @default(60)
  level4Points            Int      @default(100)
  certificationWeight     Float    @default(1.0)
  projectWeight           Float    @default(0.8)
  codeContributionWeight  Float    @default(0.7)
  peerReviewWeight        Float    @default(0.6)
  assessmentWeight        Float    @default(0.9)
  courseCompletionWeight  Float    @default(0.5)
  publicationWeight       Float    @default(0.8)
  mentoringWeight         Float    @default(0.7)
  autoValidateCertDomains String[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime

  @@index([skillId])
}

model TimelineEntry {
  id          String   @id @default(cuid())
  userId      String
  skillId     String?
  roleId      String?
  eventType   String
  title       String
  description String?
  beforeLevel Int?
  afterLevel  Int?
  eventDate   DateTime @default(now())
  evidenceIds String[]
  metadata    Json?
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventDate])
  @@index([skillId])
  @@index([userId])
}

model UserSkillEvidence {
  id                     String           @id @default(cuid())
  userId                 String
  skillId                String
  type                   EvidenceType
  title                  String
  description            String?
  url                    String?
  fileKey                String?
  issuer                 String?
  issuedAt               DateTime?
  expiresAt              DateTime?
  metadata               Json?
  status                 ValidationStatus @default(PENDING)
  validatedAt            DateTime?
  validatedBy            String?
  validationScore        Float?
  validationNotes        String?
  skillLevelContribution Int              @default(0)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime
  Skill                  Skill            @relation(fields: [skillId], references: [id], onDelete: Cascade)
  User                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([status])
  @@index([type])
  @@index([userId])
}

enum RoleLevel {
  JUNIOR
  PROFESSIONAL
  SENIOR
  TEAM_LEAD
  FUNCTIONAL_LEAD
  HEAD_OF
}

enum EvidenceType {
  CERTIFICATION
  PROJECT
  CODE_CONTRIBUTION
  PEER_REVIEW
  ASSESSMENT
  COURSE_COMPLETION
  PUBLICATION
  MENTORING
}

enum ValidationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

// ─── Learning & Career Models ───

model SkillAssessment {
  id             String   @id @default(cuid())
  userId         String
  skillId        String
  selfLevel      Int      @default(0) // 0-4
  validatedLevel Int? // Validated by Functional Lead
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
}

model CareerGoal {
  id        String           @id @default(cuid())
  userId    String
  roleId    String
  status    CareerGoalStatus @default(EXPLORING)
  priority  Int              @default(1)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  Role      Role             @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([status])
}

model LearningPlan {
  id            String          @id @default(cuid())
  userId        String          @unique
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  User          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  LearningFocus LearningFocus[]

  @@index([userId])
}

model LearningFocus {
  id                  String             @id @default(cuid())
  learningPlanId      String
  skillId             String
  competenceFieldId   String
  currentLevel        Int                @default(0)
  targetLevel         Int
  gapSize             Int
  priority            FocusPriority      @default(GROWTH)
  status              FocusStatus        @default(NOT_STARTED)
  focusOrder          Int?
  focusedAt           DateTime?
  completedAt         DateTime?
  // New: Internal project references for real-world experience tracking
  internalProjectRefs Json? // Array of { projectId, projectName, role, contribution, completedAt }
  enrichedDescription Json? // Cached AI-enriched skill description
  smartResources      Json? // Cached smart resource recommendations
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  LearningPlan        LearningPlan       @relation(fields: [learningPlanId], references: [id], onDelete: Cascade)
  Skill               Skill              @relation(fields: [skillId], references: [id])
  CompetenceField     CompetenceField    @relation(fields: [competenceFieldId], references: [id])
  EvidenceNote        EvidenceNote[]
  PracticalImpulse    PracticalImpulse[]

  @@unique([learningPlanId, skillId])
  @@index([learningPlanId])
  @@index([skillId])
  @@index([competenceFieldId])
  @@index([status])
  @@index([priority])
}

enum CareerGoalStatus {
  EXPLORING
  COMMITTED
  ACHIEVED
  ABANDONED
}

enum FocusPriority {
  CRITICAL // gapSize >= 2 OR currentLevel === 0
  GROWTH // gapSize === 1, skill in current role
  STRETCH // skill only in target role
}

enum FocusStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ─── Practical Impulse Models ───

model EvidenceNote {
  id                String        @id @default(cuid())
  learningFocusId   String
  content           String
  linkedResourceId  String?
  isAssessmentReady Boolean       @default(false)
  createdAt         DateTime      @default(now())
  LearningFocus     LearningFocus @relation(fields: [learningFocusId], references: [id], onDelete: Cascade)

  @@index([learningFocusId])
}

model PracticalImpulse {
  id              String       @id @default(cuid())
  learningFocusId String
  targetLevel     ImpulseLevel
  currentStep     ImpulseStep  @default(CHECK_IN)

  // Check-In Phase
  checkInMessage  String?
  checkInViewedAt DateTime?

  // Task Phase - Three-Step Model (Glashaus-Prinzip)
  prompt           String // Legacy field
  taskDescription  String?
  expectedOutcome  String?
  estimatedMinutes Int?
  taskStartedAt    DateTime?

  // Three-Step Structure
  vorbereitungText  String? // Step 1: Preparation
  durchfuehrungText String? // Step 2: Execution
  ergebnisCheckText String? // Step 3: Result verification

  // Interactive Scaffolding Support
  supportConcept     String? // The term/concept being explained
  supportExplanation String? // Plain-language explanation
  supportTemplate    String? // Markdown template for "Hilf mir"

  // Reflection Phase
  reflectionQuestion  String?
  userReflection      String?
  reflectionStartedAt DateTime?

  // Evidence Phase
  evidenceSaved      Boolean   @default(false)
  evidenceNoteId     String?
  evidenceSavedAt    DateTime?
  functionalLeadId   String?
  functionalLeadName String?

  // Status
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  generatedAt DateTime  @default(now())

  LearningFocus LearningFocus @relation(fields: [learningFocusId], references: [id], onDelete: Cascade)

  @@index([learningFocusId])
  @@index([isCompleted])
}

enum ImpulseLevel {
  L1_AWARENESS
  L2_GUIDED
  L3_INDEPENDENT
  L4_EXPERT
}

enum ImpulseStep {
  CHECK_IN
  TASK
  REFLECTION
  EVIDENCE
}

// ─── Platform Access & Activity Tracking ───

enum PlatformRole {
  USER // Regular user
  FUNCTIONAL_LEAD // Can access admin dashboard
  ADMIN // Full platform admin
}

enum ActivityType {
  IMPULSE_STARTED
  IMPULSE_COMPLETED
  SKILL_FOCUSED
  PLAN_CREATED
  EVIDENCE_SAVED
}

model ActivityLog {
  id           String       @id @default(cuid())
  userId       String
  activityType ActivityType
  entityId     String? // ID of related entity (impulseId, skillId, etc.)
  entityName   String? // Human-readable name for display
  metadata     Json? // Additional context (tech tags, duration, etc.)
  createdAt    DateTime     @default(now())
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([createdAt])
}

// ─── Beta Feedback System ───

model Feedback {
  id           String   @id @default(cuid())
  userId       String
  rating       String // "positive" | "negative"
  comment      String?
  contextSkill String? // Skill name for context
  contextType  String // "impulse_completed" | "skill_started"
  createdAt    DateTime @default(now())
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([rating])
}

// ─── Assessment Audit Trail ───

enum AssessmentType {
  SELF
  VALIDATED
}

model AssessmentHistory {
  id           String         @id @default(cuid())
  userId       String
  skillId      String
  level        Int
  type         AssessmentType
  assessedById String?
  createdAt    DateTime       @default(now())

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill      Skill @relation(fields: [skillId], references: [id])
  assessedBy User? @relation("AssessmentHistoryAssessor", fields: [assessedById], references: [id])

  @@index([userId, skillId, createdAt])
}

// ─── Evidence Timeline & Validation ───

enum AssessmentStatus {
  SELF_ASSESSED
  EVIDENCE_SUBMITTED
  VALIDATED
}

model Evidence {
  id             String           @id @default(cuid())
  userId         String
  skillId        String
  title          String
  description    String           @db.Text
  evidenceUrl    String?
  status         AssessmentStatus @default(SELF_ASSESSED)
  selfLevel      Int
  validatedLevel Int?
  validatedById  String?
  validatedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill            Skill             @relation(fields: [skillId], references: [id])
  validatedBy      User?             @relation("ValidatedEvidence", fields: [validatedById], references: [id])
  validationEvents ValidationEvent[]
  timelineEvents   TimelineEvent[]

  @@index([userId, skillId])
}

model ValidationEvent {
  id          String           @id @default(cuid())
  evidenceId  String
  validatorId String
  fromStatus  AssessmentStatus
  toStatus    AssessmentStatus
  comment     String?          @db.Text
  createdAt   DateTime         @default(now())

  evidence  Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  validator User     @relation(fields: [validatorId], references: [id])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  userId      String
  evidenceId  String?
  eventType   String
  title       String
  description String?  @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidence Evidence? @relation(fields: [evidenceId], references: [id])

  @@index([userId, createdAt])
}
