}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// Strukturierter Practical Impulse mit 4-Phasen Workflow (Check-In → Task → Reflexion → Evidence)
model PracticalImpulse {
  id               String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  learningFocusId  String
  targetLevel      ImpulseLevel
  prompt           String
  context          String?
  expectedOutcome  String?
  estimatedMinutes Int?
  isCompleted      Boolean       @default(false)
  userReflection   String?
  completedAt      DateTime?     @db.Timestamp(6)
  generatedAt      DateTime      @default(now()) @db.Timestamp(6)

  // Strukturierte Impulse-Felder (Convidera-Workflow)
  checkInMessage     String?                                      /// "Ich sehe, du arbeitest an [Skill] für Level [X]"
  taskDescription    String?                                      /// 30-60 Min Aufgabe für den Convidera-Alltag
  reflectionQuestion String?       @default("Was war die größte Herausforderung dabei?")

  // Evidence-Brücke zum Functional Lead
  evidenceSaved      Boolean       @default(false)
  evidenceNoteId     String?
  functionalLeadId   String?
  functionalLeadName String?

  // Step-by-Step Tracking
  currentStep        ImpulseStep   @default(CHECK_IN)
  checkInViewedAt    DateTime?     @db.Timestamp(6)
  taskStartedAt      DateTime?     @db.Timestamp(6)
  reflectionStartedAt DateTime?    @db.Timestamp(6)
  evidenceSavedAt    DateTime?     @db.Timestamp(6)

  // Relations
  LearningFocus    LearningFocus @relation(fields: [learningFocusId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  EvidenceNote     EvidenceNote? @relation(fields: [evidenceNoteId], references: [id], onUpdate: NoAction)

  @@index([learningFocusId])
  @@index([targetLevel])
  @@index([evidenceNoteId])
  @@index([currentStep])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Responsibility {
  id       String  @id
  text     String
  category String?
  order    Int     @default(0)
