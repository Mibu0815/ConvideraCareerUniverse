generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AssessmentHistory {
  id            String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId        String
  skillId       String
  previousLevel Int
  newLevel      Int
  changeType    ChangeType
  createdAt     DateTime   @default(now()) @db.Timestamp(6)
  Skill         Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User          User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([skillId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CareerGoal {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId          String
  targetRoleId    String
  timelineMonths  Int?
  status          GoalStatus        @default(EXPLORING)
  priority        Int               @default(1)
  notes           String?
  createdAt       DateTime          @default(now()) @db.Timestamp(6)
  updatedAt       DateTime          @default(now()) @db.Timestamp(6)
  Role            Role              @relation(fields: [targetRoleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User            User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  CoachingSession CoachingSession[]

  @@index([status])
  @@index([targetRoleId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CoachingMessage {
  id              String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  sessionId       String
  role            MessageRole
  content         String
  createdAt       DateTime        @default(now()) @db.Timestamp(6)
  CoachingSession CoachingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt])
  @@index([sessionId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CoachingSession {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId          String
  type            CoachingType      @default(GENERAL)
  title           String
  contextRoleId   String?
  contextSkills   Json?
  contextGoalId   String?
  createdAt       DateTime          @default(now()) @db.Timestamp(6)
  updatedAt       DateTime          @default(now()) @db.Timestamp(6)
  CoachingMessage CoachingMessage[]
  CareerGoal      CareerGoal?       @relation(fields: [contextGoalId], references: [id], onUpdate: NoAction)
  Role            Role?             @relation(fields: [contextRoleId], references: [id], onUpdate: NoAction)
  User            User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model CompetenceField {
  id                String             @id
  title             String             @unique
  slug              String             @unique
  color             String?
  ownerId           String?
  description       String?
  traxId            String?            @unique
  createdAt         DateTime?          @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?          @default(now()) @db.Timestamp(6)
  isArchived        Boolean?           @default(false)
  User              User?              @relation(fields: [ownerId], references: [id], onUpdate: NoAction)
  LearningFocus     LearningFocus[]
  LearningResource  LearningResource[]
  Skill             Skill[]
  CompetenceField_A CompetenceField[]  @relation("RelatedCompetenceFields")
  CompetenceField_B CompetenceField[]  @relation("RelatedCompetenceFields")

  @@index([ownerId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EvidenceNote {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  learningFocusId   String
  content           String
  linkedResourceId  String?
  isAssessmentReady Boolean            @default(false)
  createdAt         DateTime           @default(now()) @db.Timestamp(6)
  LearningFocus     LearningFocus      @relation(fields: [learningFocusId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  PracticalImpulse  PracticalImpulse[]

  @@index([isAssessmentReady])
  @@index([learningFocusId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model LearningFocus {
  id                String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  learningPlanId    String
  skillId           String
  currentLevel      Int
  targetLevel       Int
  priority          FocusPriority      @default(GROWTH)
  deadline          DateTime?          @db.Timestamp(6)
  status            FocusStatus        @default(NOT_STARTED)
  createdAt         DateTime           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime           @default(now()) @db.Timestamp(6)
  gapSize           Int?
  focusOrder        Int?
  focusedAt         DateTime?          @db.Timestamp(6)
  completedAt       DateTime?          @db.Timestamp(6)
  competenceFieldId String?
