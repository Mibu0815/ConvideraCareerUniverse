/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Role {
  id                       String                     @id
  title                    String
  slug                     String                     @unique
  level                    RoleLevel
  description              String?
  team                     String?                    @default("Squad")
  hasLeadership            Boolean                    @default(false)
  leadershipType           String?
  hasBudgetResp            Boolean                    @default(false)
  directReportTo           String?
  language                 String?                    @default("english")
  fieldId                  String
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime
  roleFamilyId             String?
  levelOrder               Int?                       @default(1)
  leadership               String?
  budgetResponsibility     String?
  responsibilities         Json?
  traxId                   String?                    @unique
  CareerGoal               CareerGoal[]
  CoachingSession          CoachingSession[]
  Responsibility           Responsibility[]
  OccupationalField        OccupationalField          @relation(fields: [fieldId], references: [id])
  RoleFamily               RoleFamily?                @relation(fields: [roleFamilyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  RoleSkillRequirement     RoleSkillRequirement[]
  RoleSoftSkillRequirement RoleSoftSkillRequirement[]
  User                     User[]

  @@index([fieldId])
  @@index([level])
  @@index([roleFamilyId, levelOrder])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
