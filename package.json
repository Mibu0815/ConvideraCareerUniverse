{
  "name": "career-universe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed/seed.ts",
    "db:parse": "tsx scripts/seed/parser.ts",
    "db:seed-json": "tsx scripts/seed/seed-json-roles.ts",
    "seed:skills-master": "tsx scripts/seed/seed-skills-master.ts",
    "seed:validate": "tsx scripts/seed/validate-role-json.ts",
    "seed:roles": "tsx scripts/seed/seed-json-roles.ts",
    "seed:roles-legacy": "tsx scripts/seed/seed-json-roles.ts --legacy",
    "seed:all": "npm run seed:skills-master && npm run seed:validate && npm run seed:roles",
    "seed:export-skills": "tsx scripts/seed/export-skills-to-master.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@prisma/client": "^6.0.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.94.1",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "glob": "^13.0.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.4.32",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
